{
  "name": "poker-ai-bot",
  "version": "1.0.0",
  "description": "AI Bot for Poker using Google Gemini or OpenLLama",
  "main": "bot.js",
  "scripts": {
    "start": "node bot.js",
    "format": "prettier --write .",
    "bot": "node bot.js --gameCode=LOBBY --name=Gemini_Bot",
    "llama": "node bot.js --gameCode=LOBBY --name=Llama_Bot --provider=openllama"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "ollama": "^0.6.3",
    "osolog": "^1.0.6",
    "radash": "^12.1.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1"
  }
}
